{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "esnext",
    "target": "es6",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "lib": ["dom", "es2015", "es2017"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
